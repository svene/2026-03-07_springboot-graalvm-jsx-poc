{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "genjava": "bun run javagen/generate-java-from-hono.ts",
    "build": "bun build.js",
    "build2": "bun build src/main/java/org/svenehrke/demo/web/render.tsx --format esm --outfile target/classes/static/fe/ssr.js --target bun --no-node-globals",
    "build3": "npx esbuild src/main/java/org/svenehrke/demo/web/render.tsx --bundle --platform=neutral --format=cjs --outfile=target/classes/static/fe/ssr.js",
    "watch": "bun watch.ts"
  },
  "dependencies": {
    "hono": "^4.11.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "ts-morph": "^27.0.2"
  }
}
